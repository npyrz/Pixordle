UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# timezone + automation
PIXORDLE_TIMEZONE=America/Chicago
AUTO_GENERATE_DAILY=true

# YOLO model and confidence
YOLO_MODEL=yolov8m.pt
YOLO_CONFIDENCE=0.20
YOLO_MIN_WORD_CONFIDENCE=0.25

# puzzle quality gates
PUZZLE_MIN_REVEAL_WORDS=3
PUZZLE_MAX_REVEAL_WORDS=12
PUZZLE_MAX_IMAGE_ATTEMPTS=25
PUZZLE_BLAND_LABELS=building,sky,moon,person,chair,table,tv,cell phone,cup,object

# puzzle geometry + gameplay
PUZZLE_BOARD_SIZE=420
PUZZLE_GRID_SIZE=32
PUZZLE_MAX_GUESSES=8

# comma-separated topic pool used to pick the daily query
UNSPLASH_TOPICS=pets,park,street,city,beach,kitchen,dining,food,market,sports,playground,home,office,garden,farm,transportation
