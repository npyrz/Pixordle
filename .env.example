UNSPLASH_ACCESS_KEY=your_unsplash_access_key
# optional, defaults to America/Chicago
PIXORDLE_TIMEZONE=America/Chicago
# optional, defaults to yolov8m.pt
YOLO_MODEL=yolov8m.pt
# optional, defaults to 0.20
YOLO_CONFIDENCE=0.20
# optional, comma-separated topic pool for daily image selection
UNSPLASH_TOPICS=street,nature,architecture,travel,sports,food,city,ocean,animals,fashion
# optional: auto-generate today's puzzle if file is missing when API is called
AUTO_GENERATE_DAILY=true
